{
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "framer-framer",
      "components": ["framer-framer", "react", "vue"]
    }
  ],
  "packages": {
    "packages/core": {
      "release-type": "node",
      "changelog-path": "CHANGELOG.md",
      "component": "framer-framer",
      "bump-minor-pre-major": true,
      "include-component-in-tag": false,
      "include-component-in-release": false
    },
    "packages/react": {
      "release-type": "node",
      "changelog-path": "CHANGELOG.md",
      "component": "react",
      "bump-minor-pre-major": true,
      "release-as": "3.4.0"
    },
    "packages/vue": {
      "release-type": "node",
      "changelog-path": "CHANGELOG.md",
      "component": "vue",
      "bump-minor-pre-major": true,
      "release-as": "3.4.0"
    }
  }
}
