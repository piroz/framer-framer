{
  "name": "framer-framer",
  "version": "1.2.0",
  "description": "Universal embed resolver - extract embed HTML from any URL (YouTube, X/Twitter, TikTok, Facebook, Instagram, Vimeo, Spotify, SoundCloud, and more)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format src test",
    "format:fix": "biome format --write src test",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "hono": "^4.12.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:piroz/framer-framer.git"
  },
  "author": "piroz",
  "license": "MIT",
  "bugs": "https://github.com/piroz/framer-framer/issues",
  "keywords": [
    "oembed",
    "embed",
    "iframe",
    "youtube",
    "twitter",
    "tiktok",
    "facebook",
    "instagram",
    "vimeo",
    "spotify",
    "soundcloud",
    "ogp",
    "social-media",
    "hono",
    "api",
    "server"
  ]
}
